# reuse an already established connection {{{1
Host *
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%h-%p
  ControlPersist 600

Host *analytics*.dsplatform.nl
  User ubuntu
  IdentityFile ~/.ssh/certs/analytics.pem

Host topaz
  HostName topaz.local
  User giede
  ProxyCommand ssh.exe -q -W %h:%p ark.ts